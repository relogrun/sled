OPENAI_API_KEY=

ANTHROPIC_API_KEY=

# Providers: operator (manual local mock), openai, anthropic.
SLED_PROVIDER=operator

# Optional. If unset, provider defaults are used:
# openai -> gpt-5.5
# anthropic -> claude-sonnet-4-6
# SLED_MODEL=

# Optional. If unset, all message bodies are included in context.
# SLED_RECENT_K=4

# Optional. Write message body mirrors to sidecar markdown files.
# SLED_BODY_MIRROR=true
